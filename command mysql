select *from trainer;
create table trainer(
t_id int primary key auto_increment,
t_name varchar(30) not null,
t_email varchar(40) unique not null,
t_ph varchar(20) not null,
admin_id int not null,
foreign key(admin_id) references admin(admin_id)
);

select * from batche;
create table batche(
b_id int primary key auto_increment,
b_name varchar(30) not null,
admin_id int not null,
trainer_id int not null,
foreign key(admin_id) references admin(admin_id),
foreign key(trainer_id) references trainer(t_id)
);

select * from student;
create table student(
s_id int primary key auto_increment,
s_name varchar(50) not null,
s_email varchar(50) unique not null,
s_phnum varchar(50) not null,
s_t_id int not null,
s_b_id int not null,
s_a_id int not null,
foreign key(s_t_id) references trainer(t_id),
foreign key(s_b_id) references batche(b_id)
);

